<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600" MaxHeight="600" MaxWidth="800" MinHeight="600" 
        x:Class="Den.Views.AdminEditOrdersWindow"
        Icon="avares://Den/Assets/Icon.ico"
        Title="ООО Обувь - Администратор - Список товаров">
          <Grid RowDefinitions="Auto, Auto, Auto">
            <Grid Grid.Row="0">
                <TextBlock HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Text="Изменение заказа" Name="Title" FontSize="30"></TextBlock>

                <Image HorizontalAlignment="Left" Margin="5" Width="100" Height="100" Source="C:\Users\HP\DEMO\День1\Den\Assets\Icon.JPG"></Image>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                  <Button Background="#00FA9A" Click="Button_Click1"  HorizontalAlignment="Right">
                  <TextBlock Margin="5" Foreground="White" Text="Назад"></TextBlock>       
                </Button>
                </StackPanel>
            </Grid> 
            
            <Grid ColumnDefinitions="*,*" Width="700" HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.Row="1">
              <StackPanel Orientation="Vertical" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <CalendarDatePicker Margin="10" HorizontalAlignment="Stretch" Name="Orders_date" Background="#7FFF00" Watermark="Дата заказа"> </CalendarDatePicker>
                <CalendarDatePicker Margin="10" HorizontalAlignment="Stretch" Name="Delivery_date" Background="#7FFF00" Watermark="Дата доставки"> </CalendarDatePicker>
                <ComboBox Background="#7FFF00" Margin="10" HorizontalAlignment="Stretch" Name="Pickuppoints" PlaceholderText="Пункт выдачи"></ComboBox>
                <TextBox Background="#7FFF00" Margin="10" HorizontalAlignment="Stretch" Name="Code" Watermark="Код"></TextBox>

              </StackPanel>

              <StackPanel Orientation="Vertical" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center">

                <ComboBox Background="#7FFF00" Margin="10" HorizontalAlignment="Stretch" Name="Stauts" PlaceholderText="Статус заказа"></ComboBox>
                <ComboBox Background="#7FFF00" Margin="10" HorizontalAlignment="Stretch" Name="Users" PlaceholderText="Пользователь"></ComboBox>
                <StackPanel Orientation="Vertical">
                  <StackPanel HorizontalAlignment="Stretch" Orientation="Horizontal" Margin="10">
                    <ComboBox Name="Products" Width="150" Background="#7FFF00" PlaceholderText="Выбрать товар">
                    </ComboBox>
                    <Button Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#00FA9A" Click="Add_Tovar" >
                      <TextBlock Margin="5" Foreground="White" Text="Добавить товар"></TextBlock>       
                    </Button>
                  </StackPanel>
                  <ScrollViewer Height="150" HorizontalAlignment="Stretch" Margin="5">
                    <StackPanel Name="MyProducts" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                    </StackPanel>
                  </ScrollViewer>
                
                </StackPanel>
                
              </StackPanel>
            </Grid>

            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.Row="2">
              <Button Margin="10" Click="Save_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#00FA9A"  >
                  <TextBlock Margin="5" Foreground="White" Text="Сохранить"></TextBlock>       
                </Button>
            </Grid>
            
            
        </Grid>    
</Window>